{
    "name": "contactjavas/modern-wpcs-ruleset",
    "type": "phpcodesniffer-standard",
    "keywords": [ "phpcs", "static analysis" ],
    "description": "A PHPCS meta-ruleset for modern WordPress development",
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/contactjavas/modern-wpcs-standard"
        },
        {
            "type": "vcs",
            "url": "https://github.com/contactjavas/phpcs-import-detection"
        },
        {
            "type": "vcs",
            "url": "https://github.com/contactjavas/wpcs"
        }
    ],
    "require": {
        "php": "^8.2 || ^8.3 || ^8.4 || ^8.5",
        "contactjavas/modern-wpcs-standard": "^2.0.0",
        "contactjavas/phpcs-import-detection": "^2.0.0",
        "sirbrillig/phpcs-variable-analysis": "^2.13.0",
        "contactjavas/wpcs": "^4.0.0"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2.1",
        "squizlabs/php_codesniffer": "^4.0.1"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
